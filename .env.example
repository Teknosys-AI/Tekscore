# Copy to .env on your machine and on the VM. Never commit .env.
# Path on VM: same directory as app.py and config.py (e.g. .../JSCOREWEBPORTAL/.env)

# Use a long random string in production (e.g. openssl rand -hex 32)
SECRET_KEY=generate-a-long-random-string

# JScore API (adjust host if your gateway changes)
API_ENDPOINT=https://119.160.107.171:8243/fusionapi/1.0/fusionapi/JScore
HISTORYAPI_ENDPOINT=https://quanticaapi.jazz.com.pk/jscore/Jazz_Score_history

# Production MySQL (URL-encode special characters in the password, e.g. @ -> %40)
# Example shape: mysql://DB_USER:DB_PASSWORD@DB_HOST:3306/jscore
SQLALCHEMY_DATABASE_URI=mysql://jscore_user:YOUR_PASSWORD_URL_ENCODED@192.168.209.38:3306/jscore

SESSION_COOKIE_HTTPONLY=true
# Set false only for local HTTP without TLS; use true behind HTTPS in production
SESSION_COOKIE_SECURE=true

# Optional: scripts/update_token.py maintenance only
# WORKING_TOKEN=
